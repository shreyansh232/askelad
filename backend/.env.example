# Core
DEBUG=false
SECRET_KEY=generate-a-strong-random-secret-here-min-32-chars

# Database
DATABASE_URL=postgresql+asyncpg://askelad_user:askelad_password@localhost:5432/askelad

# Redis (optional - for future background tasks)
REDIS_URL=redis://localhost:6379

# Google OAuth (required for login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/callback

# Frontend URL (your Vercel domain or custom domain)
FRONTEND_URL=https://your-frontend-domain.com

# OpenAI (required for agent LLM calls)
OPENAI_API_KEY=sk-proj-your-openai-key

# LiteLLM (optional - for multi-provider routing)
# LITELLM_API_KEY=
# LITELLM_BASE_URL=

# Pinecone (required for document indexing)
PINECONE_API_KEY=pcsk-your-pinecone-key
PINECONE_INDEX_NAME=askelad

# Supabase (optional - for PDF storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_BUCKET=PDFs

# Tavily (optional - for web search in agents)
TAVILY_API_KEY=tvly-your-tavily-key
